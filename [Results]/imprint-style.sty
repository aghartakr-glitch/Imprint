% Generated: Imprint v1.3.0 — 2026-06-19
% 학습된 피드백 규칙 (10개): column_count: +2% [high], font_style: serif [high], body_leading: +5% [high], margin_bottom: -20% [high], margin_outer: -30% [high], footnote_size: 0% [high], footnote_leading: -28% [high], heading_layout: left [high], heading_gap: -40% [high], body_gap: +10% [high]
% ============================================================
%
% 필요한 폰트 파일 (main.tex과 같은 폴더의 fonts/ 하위에 저장):
%   fonts/Pretendard-Regular.otf
%   fonts/Pretendard-Bold.otf
%   fonts/NotoSans-Regular.ttf
%   fonts/NotoSans-Bold.ttf
%   fonts/NotoSans-Italic.ttf
%   fonts/NotoSans-BoldItalic.ttf
%
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{imprint-style}[2026/06/19 Imprint generated style]

% ── 이전 bigfoot 빌드 .aux 호환 — perpage \pp@spagectr 미정의 오류 방지 ──
% bigfoot(perpage)가 이전 컴파일에서 .aux에 기록한 \pp@spagectr를
% 이 sty에서 no-op으로 제공해 오류 루프를 끊는다. 다음 컴파일부터는 .aux에 없음.
\providecommand{\pp@spagectr}[4]{}

% ── 필수 패키지 ───────────────────────────────────────────────
\RequirePackage{fontspec}
\RequirePackage{geometry}
\RequirePackage{needspace}
\RequirePackage{multicol}
\RequirePackage{ragged2e}

% ── 판형 / 여백 ───────────────────────────────────────────────
% 186×243mm — 건축 도록으로서 텍스트, 전시 전경, 도면, 모형 사진, 인터뷰, 인덱스를 충분히 수용할 수 있는 중대형 판형이다. 전시장 사진의 스케일과 건축 이미지의 물성을 살리면서도, 사선 분할과 좌우 색조 변화 같은 시스템적 편집 원리를 넉넉하게 전개하기에 적절한 크기다.
% 여백 의도: 기본적으로는 사진과 본문, 캡션, 장 제목이 안정적으로 놓일 수 있도록 비교적 균형 잡힌 여백 구조를 유지하지만, 진짜 핵심은 사방 여백보다 좌우 페이지의 상반된 바탕과 질감이 만드는 시각적 프레임이다. 왼쪽 페이지의 빗금, 오른쪽 페이지의 점 망점, 그리고 중앙을 기준으로 한 색조 이동이 여백 이상의 구조적 역할을 수행한다.
\geometry{
  paperwidth=186mm, paperheight=243mm,
  top=12mm, bottom=17.6mm,
  inner=15mm, outer=10.5mm,
  includehead=true, includefoot=true,
  headheight=15pt, headsep=4mm,
  footskip=10mm,
}

% ── 서체 ──────────────────────────────────────────────────────
% 서체 선택 이유: 건축 도록의 정보성과 구조성을 드러내기 위해 강한 고딕 및 컨덴스드 디스플레이 서체를 중심으로 사용한 것으로 보인다. ‘BEFORE’, ‘AFTER’, 장 제목, 인덱스는 압축된 활자로 건축적 질서와 힘을 만들고, 본문과 캡션은 보다 중립적인 서체로 읽기 흐름을 유지한다. 서로 다른 서체 계열의 병용은 책의 이분법적 구조와 매체적 층위를 명확하게 드러낸다.
% XeLaTeX 전용 (fontspec) — pdfLaTeX 미지원
% Fonts — 가용: NotoSerif / NanumMyeongjo / Pretendard / NotoSans_SemiCondensed
% 원본 서체: 격동고딕, 드루크 컨덴스드, 산돌 고딕네오, 이그제큐티브 (고딕)
\setmainfont{Pretendard}[
  Path=./fonts/,
  Extension=.otf,
  UprightFont=Pretendard-Regular,
  BoldFont=Pretendard-Bold
]
% sans = main (단일 서체군)


% ── 본문 타이포그래피 ─────────────────────────────────────────
% 7pt / 행간 14.7pt / 자간 -20
% 자간 이유: 본문과 캡션은 건축 정보의 판독성을 위해 중립 자간과 넉넉한 행간을 유지하지만, ‘BEFORE/AFTER’나 대형 장 제목은 압축된 폭과 더 촘촘한 밀도로 사용되어 구조적 긴장과 시간적 절단을 강조한다. 즉 읽기용 텍스트와 구조용 타이포그래피의 리듬이 분리되어 있다.
\AtBeginDocument{\fontsize{7pt}{14.7pt}\selectfont}
\setlength{\parindent}{1em}
\setlength{\parskip}{0pt}
\widowpenalty=10000
\clubpenalty=10000
\displaywidowpenalty=10000
\pretolerance=100
\tolerance=400
\emergencystretch=3em

% ── 본문 정렬: 좌측 정렬 ────────────────────────────────
\AtBeginDocument{\RaggedRight}

% ── 단 구성: 2단 / 간격 6mm ──────────────────────────────────────
% 레이아웃 유형: 본문 2단 — 책은 전시장 입구처럼 보이는 빈 공간 사진으로 시작해 전시가 가득 찬 장면으로 끝나며, 자료는 현장–설계–시공–완공–사용이라는 흐름을 따라 배치된다. 목차는 원형 노드 구조로 장의 관계를 도식화하고, 본문에서는 흰 면과 검은 면, 거친 망점 질감, 대형 압축 타이포그래피, 전면 사진, 다중 이미지 배열이 교차한다. ‘BEFORE/AFTER’라는 표제는 단순한 장식이 아니라 페이지 양쪽의 색과 내용, 시간성을 동시에 구획하는 구조 장치로 작동한다. 전체적으로 책의 시작과 끝, 좌와 우, 전과 후가 서로 대응하며 순환하는 건축적 편집 시스템을 이룬다.
\setlength{\columnsep}{6mm}

% ── 위계별 글자 크기 명령 ─────────────────────────────────────
% 본문에서 \hone \htwo \hthree \bodyf 사용
% Heading sizes — DO NOT OVERRIDE sizes or weights
\newcommand{\hone}{\bfseries\fontsize{15.5pt}{21.7pt}\selectfont \raggedright}   % title
\newcommand{\htwo}{\bfseries\fontsize{9.5pt}{15.2pt}\selectfont \raggedright}   % subtitle/chapter
\newcommand{\hthree}{\bfseries\fontsize{8pt}{13.2pt}\selectfont \raggedright} % section head
\newcommand{\bodyf}{\normalfont\fontsize{7pt}{14.7pt}\selectfont} % body reset after heading

% ── 제목↔소제목 간격 (피드백 규칙 반영) ────────────────────────
\newlength{\imprintheadinggap}
\setlength{\imprintheadinggap}{6.6pt}
% ── 제목/소제목↔본문 간격 ───────────────────────────────────────
\newlength{\imprintbodygap}
\setlength{\imprintbodygap}{16.2pt}

% ── 각주 ──────────────────────────────────────────────────────
% 크기: 9.5pt / 정렬: 좌측 정렬
\feetbelowfloat
\renewcommand{\footnoterule}{}
\renewcommand{\footnotesize}{\fontsize{7pt}{8.9pt}\selectfont}
\newcommand{\notef}{\sffamily\fontsize{7pt}{8.9pt}\selectfont}
\providecommand{\foottextfont}{\footnotesize}
\renewcommand{\foottextfont}{\notef}
\renewcommand{\thefootnote}{\arabic{footnote}}
\setlength{\footnotesep}{10.7pt}
\makeatletter
\renewcommand\@makefntext[1]{%
  \parindent\z@\hangindent1.5em\relax
  \noindent\makebox[1.5em][l]{\notef\@thefnmark.}\,{\notef #1}}
\makeatother

% ── 면주 / 쪽번호 (memoir pagestyle) ─────────────────────────
% 쪽번호: 하단-외측-가로 / 면주: 자동 / 크기: 36pt
% ── 면주 / 쪽번호 macro (memoir 전용) ────────────────────────
% pn-status: active
\newcommand{\foliof}{\sffamily\fontsize{9pt}{11pt}\selectfont}
\newcommand{\runningheadf}{\sffamily\fontsize{9pt}{11pt}\selectfont}
\newcommand{\imprintrunninghead}{}
\makepagestyle{imprint}
\makeheadrule{imprint}{\textwidth}{0pt}
\makefootrule{imprint}{\textwidth}{0pt}{0pt}
\makeoddhead{imprint}{}{}{\runningheadf\imprintrunninghead}
\makeevenhead{imprint}{\runningheadf\imprintrunninghead}{}{}
\makeoddfoot{imprint}{}{}{\foliof\thepage}
\makeevenfoot{imprint}{\foliof\thepage}{}{}

% ── 대화문 / 인용문 환경 ──────────────────────────────────────
% main.tex에서 \begin{imprintdialogue}...\end{imprintdialogue} 로 사용
\newenvironment{imprintdialogue}{%
  \par
  \vspace{0.25\baselineskip}
  \begingroup
  \bodyf
  \setlength{\leftskip}{1em}
  \setlength{\rightskip}{1em}
  \noindent
}{%
  \par
  \endgroup
  \vspace{0.25\baselineskip}
}
% main.tex에서 \begin{imprintquote}...\end{imprintquote} 로 사용
\newenvironment{imprintquote}{%
  \par
  \vspace{0.5\baselineskip}
  \begingroup
  \bodyf
  \setlength{\leftskip}{1.5em}
  \setlength{\rightskip}{1.5em}
  \noindent
}{%
  \par
  \endgroup
  \vspace{0.5\baselineskip}
}

\endinput